APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
PRIVACY_POLICY_VERSION=20260214

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Enable or disable the games calendar view
FEATURE_GAMES_CALENDAR=true
FEATURE_ROOMS=true
FEATURE_CHARACTER_STATUS_SWITCH=false

VITE_APP_NAME="${APP_NAME}"
VITE_IMPRESSUM_NAME="Max Mustermann"
VITE_IMPRESSUM_STREET="Hauptstraße 1"
VITE_IMPRESSUM_CITY="12345 Musterstadt"
VITE_IMPRESSUM_EMAIL="max@muster.de"

# Discord OAuth (App)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI="${APP_URL}/auth/callback"

# Discord Bot (uses the SAME .env as the app)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_IDS=
DISCORD_COMMAND_PREFIX=wwt
BOT_LOCALE=de
DISCORD_SUPPORT_STAFF_ROLE_IDS=
DISCORD_CHANNEL_OVERRIDE_ID=

# Bot HTTP control (app -> bot)
BOT_HTTP_URL=
BOT_HTTP_TOKEN=
BOT_APP_URL=
BOT_PUBLIC_APP_URL=
BOT_HTTP_HOST=127.0.0.1
BOT_HTTP_PORT=3125
BOT_HTTP_RATE_LIMIT_MS=15000
BOT_HTTP_TIMEOUT=120
BOT_BACKUP_BATCH_SIZE=100
BOT_BACKUP_DELAY_MS=1200
BOT_BACKUP_ATTACHMENT_DELAY_MS=250
