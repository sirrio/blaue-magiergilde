{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:ssr": "vite build && vite build --ssr",
    "db:restore-prod-backup": "powershell -ExecutionPolicy Bypass -File tools/restore-db-from-backup.ps1",
    "dev": "vite",
    "dev:queue": "php artisan queue:work --tries=1",
    "dev:schedule": "php artisan schedule:work",
    "dev:bot": "node bot/index.js",
    "dev:stack": "concurrently --kill-others -c \"#fdba74,#c4b5fd,#93c5fd,#34d399\" --names \"vite,queue,schedule,bot\" \"npm:dev\" \"npm:dev:queue\" \"npm:dev:schedule\" \"npm:dev:bot\"",
    "format": "prettier --write resources/",
    "format:check": "prettier --check resources/",
    "lint": "eslint . --fix",
    "types": "tsc --noEmit",
    "share": "herd share https://blaue-magiergilde.test/"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
